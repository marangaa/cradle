{
  "name": "@cradle/video",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts CradleLaunch out/cradle-launch.mp4",
    "render:preview": "remotion render src/index.ts CradleLaunch out/cradle-launch-preview.mp4 --scale=0.6667",
    "still": "remotion still src/index.ts LaunchThumbnail out/cradle-thumbnail.png",
    "voice": "tsx scripts/generate-voice.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.495",
    "dotenv": "^17.4.2",
    "remotion": "4.0.495"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.23.1",
    "typescript": "5.9.2"
  }
}
