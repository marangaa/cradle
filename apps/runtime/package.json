{
  "name": "runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @cradle/widget build && node scripts/copy-widget.mjs && node --env-file=../../.env node_modules/next/dist/bin/next dev --port 3002",
    "build": "pnpm --filter @cradle/widget build && node scripts/copy-widget.mjs && next build",
    "start": "next start -p 3002",
    "lint": "eslint --max-warnings 0",
    "check-types": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.16",
    "@cradle/agent": "workspace:*",
    "@cradle/core": "workspace:*",
    "@cradle/db": "workspace:*",
    "@cradle/crawler": "workspace:*",
    "@cradle/widget": "workspace:*",
    "ai": "^7.0.31",
    "next": "16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "typescript": "5.9.2"
  }
}
