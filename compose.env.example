OPENAI_API_KEY=your_openai_api_key
FIRECRAWL_API_KEY=your_firecrawl_api_key
CRADLE_MODEL_ID=gpt-5.6-sol
CRADLE_WIDGET_TOKEN_SECRET=replace_with_a_random_32_byte_secret
CRADLE_STUDIO_ORIGIN=http://localhost:3000
# Optional: use only while embedding a crawl of a public site into a local site.
CRADLE_DEVELOPMENT_EMBED_ORIGIN=http://localhost:3004
# This is baked into the Studio browser bundle during Docker image build.
CRADLE_STUDIO_RUNTIME_URL=http://localhost:3002
# Optional override for non-Docker self-hosts. Docker mounts /app/data/assets automatically.
CRADLE_ASSET_DIRECTORY=/app/data/assets
# Set to `s3` for Qualra Cloud, R2, S3, or MinIO; otherwise filesystem is used.
CRADLE_ASSET_STORAGE=filesystem
# CRADLE_ASSET_BUCKET=cradle-assets
# CRADLE_ASSET_REGION=us-east-1
# CRADLE_ASSET_ENDPOINT=https://your-s3-compatible-endpoint
# CRADLE_ASSET_ACCESS_KEY_ID=...
# CRADLE_ASSET_SECRET_ACCESS_KEY=...
